# Minimal .env example for IMTB-D
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-********************************
IMTBD_API_BASE=http://127.0.0.1:8765
IMTBD_JSONL_PATH=\\\\任意のパス\\IMTB-D\\messages.jsonl

# Optional
OPENAI_MODEL=gpt-4o-mini
PREFERRED_LANG=ja
DEFAULT_REPLY_LANG=en

# （任意）UIからローカルRelayを起動するコマンドを上書き
# IMTBD_RELAY_CMD=python IMTB-D_relay.py